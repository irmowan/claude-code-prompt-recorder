{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/scripts/record-prompt.py",
            "description": "Record user prompts to a file",
            "async": true,
            "timeout": 10
          }
        ]
      }
    ]
  }
}
